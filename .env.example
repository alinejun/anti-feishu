# Feishu App Credentials (from Feishu Open Platform)
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# CDP Configuration
CDP_PORT=9222
CDP_HOST=localhost

# Security
FEISHU_ALLOWED_USER_IDS=ou_xxxxxxxxxxxx

# Agent Monitor
MONITOR_INTERVAL_MS=3000
MONITOR_ENABLED=true

# Auto Accept
AUTO_ACCEPT_ENABLED=false
AUTO_ACCEPT_BLOCKED_COMMANDS=rm -rf,sudo,mkfs,format,drop table,drop database,shutdown,reboot,dd if=,chmod -R 777,git push --force,git reset --hard

# Logging
LOG_LEVEL=info
