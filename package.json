{
  "name": "anti-feishu",
  "version": "0.1.0",
  "description": "Control Antigravity Agent remotely via Feishu Bot",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "stop": "lsof -ti :3000 | xargs kill -2 2>/dev/null || echo 'Not running'",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "antigravity",
    "feishu",
    "cdp",
    "bot"
  ],
  "license": "MIT",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.40.0",
    "@types/ws": "^8.18.1",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "puppeteer-core": "^24.4.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
